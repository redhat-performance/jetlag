{
  "ignition": {
{% if openshift_version is version('4.8', ">=") %}
    "version": "3.2.0"
{% else %}
    "version": "3.1.0"
{% endif %}
  },
  "storage": {
    "disks": [
{% for device in worker_localstorage_lvm_devices %}
      {
        "device": "{{ device }}",
        "wipeTable": true,
        "partitions": [
{% if worker_localstorage_lvm_devices | length > 0 %}
          {
            "label": "LS{{ loop.index0 }}",
            "sizeMiB": 0
          }
{% endif %}
        ]
{% if not loop.last or worker_localstorage_disk_devices %}
      },
{% else %}
      }
{% endif %}
{% endfor %}
{% for device in worker_localstorage_disk_devices %}
      {
        "device": "{{ device }}",
        "wipeTable": true,
        "partitions": []
{% if not loop.last %}
      },
{% else %}
      }
{% endif %}
{% endfor %}
    ],
    "files": [
{% if worker_localstorage_lvm_devices | length > 0 %}
      {
        "contents": {
          "source": "data:text/plain;base64,{{ lookup('template', './worker-setup-lvm.sh.j2') | b64encode }}"
        },
        "mode": 493,
        "overwrite": true,
        "path": "/usr/local/bin/setup-lvm.sh"
      }
{% endif %}
    ]
  },
  "systemd": {
    "units": [
{% if worker_localstorage_lvm_devices | length > 0 %}
      {
        "name": "setup-localstorage.service",
        "enabled": true,
        "contents": "[Unit]\nConditionPathExists=!/var/lib/lvm-setup-complete\n\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/setup-lvm.sh\nExecStartPost=/usr/bin/touch /var/lib/lvm-setup-complete\n[Install]\nWantedBy=multi-user.target"
      }
{% endif %}
    ]
  }
}
