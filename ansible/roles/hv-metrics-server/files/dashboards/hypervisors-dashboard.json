{
  "title": "Hypervisors Dashboard",
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "text": "1m",
          "value": "1m"
        }
      },
      {
        "name": "job",
        "type": "query",
        "label": "Job Selection",
        "datasource": null,
        "query": {
          "query": "label_values(node_cpu_seconds_total{job!~\"bastion|bastion-system\"}, job)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 1
      },
      {
        "name": "interface",
        "type": "query",
        "label": "Network Interface",
        "datasource": null,
        "query": {
          "query": "label_values(node_network_receive_bytes_total{job=~\"$job\", device!~\"lo|veth.*|br-.*|cni.*|ovs.*|virbr.*|flannel.*|cali.*|tunl.*|docker.*|podman.*\"}, device)",
          "refId": "StandardVariableQuery"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 1
      },
      {
        "name": "disk",
        "type": "query",
        "label": "Disk Device",
        "datasource": null,
        "query": {
          "query": "label_values(node_disk_reads_completed_total{job=~\"$job\"}, device)",
          "refId": "StandardVariableQuery"
        },
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "sda",
          "value": "sda"
        },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "title": "Compute (CPU)",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "title": "CPU Utilization (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "avg(1 - rate(node_cpu_seconds_total{job=~\"$job\",job!~\"bastion|bastion-system\", mode='idle'}[$interval])) by (job) * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "CPU Cores Used",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(1 - rate(node_cpu_seconds_total{job=~\"$job\",job!~\"bastion|bastion-system\", mode='idle'}[$interval])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Load Average",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_load1{job=~\"$job\",job!~\"bastion|bastion-system\"}",
          "legendFormat": "{{job}} 1m"
        },
        {
          "expr": "node_load5{job=~\"$job\",job!~\"bastion|bastion-system\"}",
          "legendFormat": "{{job}} 5m"
        },
        {
          "expr": "node_load15{job=~\"$job\",job!~\"bastion|bastion-system\"}",
          "legendFormat": "{{job}} 15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+)(.*)",
            "renamePattern": "$1$2"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Memory Metrics",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "title": "Memory Utilization (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=~\"$job\",job!~\"bastion|bastion-system\"} / node_memory_MemTotal_bytes{job=~\"$job\",job!~\"bastion|bastion-system\"}) * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Memory Used",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=~\"$job\",job!~\"bastion|bastion-system\"} - node_memory_MemAvailable_bytes{job=~\"$job\",job!~\"bastion|bastion-system\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Disk Space",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      }
    },
    {
      "title": "Root (/) Space Used",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum(node_filesystem_size_bytes{job=~\"$job\",job!~\"bastion|bastion-system\", mountpoint=\"/\"} - node_filesystem_avail_bytes{job=~\"$job\",job!~\"bastion|bastion-system\", mountpoint=\"/\"}) by (job)",
          "legendFormat": "{{job}} used"
        },
        {
          "expr": "sum(node_filesystem_size_bytes{job=~\"$job\",job!~\"bastion|bastion-system\", mountpoint=\"/\"}) by (job)",
          "legendFormat": "{{job}} total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Root (/) Usage (%)",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 19
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=~\"$job\",job!~\"bastion|bastion-system\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=~\"$job\",job!~\"bastion|bastion-system\", mountpoint=\"/\"}) * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ]
    },
    {
      "title": "All Mountpoints Space Used",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{job=~\"$job\",job!~\"bastion|bastion-system\", fstype!~\"tmpfs|overlay\"} - node_filesystem_avail_bytes{job=~\"$job\",job!~\"bastion|bastion-system\", fstype!~\"tmpfs|overlay\"}",
          "legendFormat": "{{job}} {{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Disk I/O",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      }
    },
    {
      "title": "IOPS",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "rate(node_disk_reads_completed_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$disk\"}[$interval])",
          "legendFormat": "{{job}} reads"
        },
        {
          "expr": "rate(node_disk_writes_completed_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$disk\"}[$interval])",
          "legendFormat": "{{job}} writes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Throughput",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 28
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$disk\"}[$interval])",
          "legendFormat": "{{job}} read"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$disk\"}[$interval])",
          "legendFormat": "{{job}} write"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "I/O Utilization (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "targets": [
        {
          "expr": "rate(node_disk_io_time_seconds_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$disk\"}[$interval]) * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "([^.:]+).*",
            "renamePattern": "$1"
          }
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ]
        }
      }
    },
    {
      "title": "Network Interfaces",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "collapsed": true,
      "panels": [
        {
          "title": "Network: All Physical Interfaces Bandwidth",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 28
          },
          "targets": [
            {
              "expr": "rate(node_network_receive_bytes_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$interface\"}[$interval]) * 8",
              "legendFormat": "{{job}} {{device}} Rx"
            },
            {
              "expr": "rate(node_network_transmit_bytes_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$interface\"}[$interval]) * 8",
              "legendFormat": "{{job}} {{device}} Tx"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "bps"
            }
          },
          "transformations": [
            {
              "id": "renameByRegex",
              "options": {
                "regex": "([^.: ]+)(.*)",
                "renamePattern": "$1$2"
              }
            }
          ],
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "min",
                "max"
              ]
            }
          }
        },
        {
          "title": "Network: Total Received",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 36
          },
          "targets": [
            {
              "expr": "rate(node_network_receive_bytes_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$interface\"}[$interval])",
              "legendFormat": "{{job}} {{device}} Rx"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps"
            }
          },
          "transformations": [
            {
              "id": "renameByRegex",
              "options": {
                "regex": "([^.: ]+)(.*)",
                "renamePattern": "$1$2"
              }
            }
          ],
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "min",
                "max"
              ]
            }
          }
        },
        {
          "title": "Network: Total Transmitted",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 36
          },
          "targets": [
            {
              "expr": "rate(node_network_transmit_bytes_total{job=~\"$job\",job!~\"bastion|bastion-system\", device=~\"$interface\"}[$interval])",
              "legendFormat": "{{job}} {{device}} Tx"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps"
            }
          },
          "transformations": [
            {
              "id": "renameByRegex",
              "options": {
                "regex": "([^.: ]+)(.*)",
                "renamePattern": "$1$2"
              }
            }
          ],
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "min",
                "max"
              ]
            }
          }
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1,
  "uid": "hypervisor-metrics",
  "timezone": "utc"
}
