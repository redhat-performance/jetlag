#!/bin/bash
# Collects mirror registry metrics for the node-exporter textfile collector:
#  - Network traffic counters via iptables accounting chains (IPv4 + IPv6)
#  - Container CPU and memory usage via cgroup files
#  - Active connection count via ss

TEXTFILE_DIR="{{ hv_metrics_server_bastion_exporter_textfile_dir }}"
REGISTRY_PORT="{{ registry_port }}"
REGISTRY_CONTAINER="bastion-registry"
PROM_FILE="${TEXTFILE_DIR}/registry_traffic.prom"
TMP_FILE="${PROM_FILE}.tmp"

setup_rules() {
  local cmd=$1
  $cmd -N REGISTRY_RX 2>/dev/null || true
  $cmd -N REGISTRY_TX 2>/dev/null || true
  $cmd -C REGISTRY_RX -j RETURN 2>/dev/null || $cmd -A REGISTRY_RX -j RETURN
  $cmd -C REGISTRY_TX -j RETURN 2>/dev/null || $cmd -A REGISTRY_TX -j RETURN
  $cmd -C INPUT -p tcp --dport "${REGISTRY_PORT}" -j REGISTRY_RX 2>/dev/null || \
    $cmd -I INPUT -p tcp --dport "${REGISTRY_PORT}" -j REGISTRY_RX
  $cmd -C OUTPUT -p tcp --sport "${REGISTRY_PORT}" -j REGISTRY_TX 2>/dev/null || \
    $cmd -I OUTPUT -p tcp --sport "${REGISTRY_PORT}" -j REGISTRY_TX
}

read_counter() {
  local cmd=$1
  local chain=$2
  local field=$3
  $cmd -L "$chain" -v -n -x 2>/dev/null | awk '/RETURN/ {print $'"$field"'}'
}

# --- Network traffic ---

setup_rules iptables
setup_rules ip6tables

rx4_bytes=$(read_counter iptables REGISTRY_RX 2)
tx4_bytes=$(read_counter iptables REGISTRY_TX 2)
rx4_packets=$(read_counter iptables REGISTRY_RX 1)
tx4_packets=$(read_counter iptables REGISTRY_TX 1)

rx6_bytes=$(read_counter ip6tables REGISTRY_RX 2)
tx6_bytes=$(read_counter ip6tables REGISTRY_TX 2)
rx6_packets=$(read_counter ip6tables REGISTRY_RX 1)
tx6_packets=$(read_counter ip6tables REGISTRY_TX 1)

rx_bytes=$(( ${rx4_bytes:-0} + ${rx6_bytes:-0} ))
tx_bytes=$(( ${tx4_bytes:-0} + ${tx6_bytes:-0} ))
rx_packets=$(( ${rx4_packets:-0} + ${rx6_packets:-0} ))
tx_packets=$(( ${tx4_packets:-0} + ${tx6_packets:-0} ))

# --- Container CPU and memory via cgroup ---

cpu_seconds="0"
mem_bytes="0"
mem_working_set_bytes="0"
mem_limit="0"

REGISTRY_PID=$(podman inspect --format '{% raw %}{{.State.Pid}}{% endraw %}' "$REGISTRY_CONTAINER" 2>/dev/null)

if [[ -n "$REGISTRY_PID" && "$REGISTRY_PID" != "0" ]]; then
  CGROUP=$(head -1 /proc/${REGISTRY_PID}/cgroup 2>/dev/null | cut -d: -f3)
  CGROUP_DIR="/sys/fs/cgroup${CGROUP}"

  if [[ -d "$CGROUP_DIR" ]]; then
    cpu_usec=$(awk '/^usage_usec/ {print $2}' "${CGROUP_DIR}/cpu.stat" 2>/dev/null)
    cpu_seconds=$(echo "${cpu_usec:-0}" | awk '{printf "%.6f", $1/1000000}')
    mem_bytes=$(cat "${CGROUP_DIR}/memory.current" 2>/dev/null || echo "0")

    inactive_file=$(awk '/^inactive_file / {print $2; exit}' "${CGROUP_DIR}/memory.stat" 2>/dev/null)
    inactive_file=${inactive_file:-0}
    if [[ "$mem_bytes" -gt "$inactive_file" ]]; then
      mem_working_set_bytes=$(( mem_bytes - inactive_file ))
    fi

    raw_limit=$(cat "${CGROUP_DIR}/memory.max" 2>/dev/null)
    if [[ "$raw_limit" != "max" ]]; then
      mem_limit="$raw_limit"
    fi
  fi
fi

# --- Connection count ---

conn_count_v4=$(ss -Htn4 state established sport = :${REGISTRY_PORT} 2>/dev/null | wc -l)
conn_count_v6=$(ss -Htn6 state established sport = :${REGISTRY_PORT} 2>/dev/null | wc -l)
conn_count=$(( ${conn_count_v4:-0} + ${conn_count_v6:-0} ))
conn_count=${conn_count:-0}

# --- Write metrics ---

cat > "${TMP_FILE}" << EOF
# HELP registry_network_receive_bytes_total Bytes received by the mirror registry (port ${REGISTRY_PORT}).
# TYPE registry_network_receive_bytes_total counter
registry_network_receive_bytes_total{port="${REGISTRY_PORT}",service="mirror_registry"} ${rx_bytes}
# HELP registry_network_transmit_bytes_total Bytes transmitted by the mirror registry (port ${REGISTRY_PORT}).
# TYPE registry_network_transmit_bytes_total counter
registry_network_transmit_bytes_total{port="${REGISTRY_PORT}",service="mirror_registry"} ${tx_bytes}
# HELP registry_network_receive_packets_total Packets received by the mirror registry (port ${REGISTRY_PORT}).
# TYPE registry_network_receive_packets_total counter
registry_network_receive_packets_total{port="${REGISTRY_PORT}",service="mirror_registry"} ${rx_packets}
# HELP registry_network_transmit_packets_total Packets transmitted by the mirror registry (port ${REGISTRY_PORT}).
# TYPE registry_network_transmit_packets_total counter
registry_network_transmit_packets_total{port="${REGISTRY_PORT}",service="mirror_registry"} ${tx_packets}
# HELP registry_container_cpu_usage_seconds_total Cumulative CPU time consumed by the registry container.
# TYPE registry_container_cpu_usage_seconds_total counter
registry_container_cpu_usage_seconds_total{container="${REGISTRY_CONTAINER}"} ${cpu_seconds}
# HELP registry_container_memory_usage_bytes Current memory usage of the registry container (includes page cache).
# TYPE registry_container_memory_usage_bytes gauge
registry_container_memory_usage_bytes{container="${REGISTRY_CONTAINER}"} ${mem_bytes}
# HELP registry_container_memory_working_set_bytes Working set memory of the registry container (excludes reclaimable page cache).
# TYPE registry_container_memory_working_set_bytes gauge
registry_container_memory_working_set_bytes{container="${REGISTRY_CONTAINER}"} ${mem_working_set_bytes}
# HELP registry_container_memory_limit_bytes Memory limit of the registry container (0 if unlimited).
# TYPE registry_container_memory_limit_bytes gauge
registry_container_memory_limit_bytes{container="${REGISTRY_CONTAINER}"} ${mem_limit}
# HELP registry_network_connections Current number of established connections to the registry.
# TYPE registry_network_connections gauge
registry_network_connections{port="${REGISTRY_PORT}",service="mirror_registry"} ${conn_count}
EOF

mv "${TMP_FILE}" "${PROM_FILE}"
