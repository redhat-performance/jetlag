apiVersion: v1
kind: Pod
metadata:
  name: {{ hv_metrics_server_pod_name }}
spec:
  hostNetwork: true
  containers:
    - name: {{ hv_metrics_server_prometheus_container_name }}
      image: {{ hv_metrics_server_prometheus_container_image }}
      args:
        - "--config.file=/etc/prometheus/prometheus.yaml"
        - "--storage.tsdb.path=/prometheus"
        - "--storage.tsdb.retention.time={{ hv_metrics_server_retention_time }}"
      ports:
        - containerPort: 9090
      volumeMounts:
        - name: prometheus-data
          mountPath: /prometheus
        - name: prometheus-config
          mountPath: /etc/prometheus/prometheus.yaml
          readOnly: true
{% if hv_metrics_server_deploy_grafana %}
    - name: {{ hv_metrics_server_grafana_container_name }}
      image: {{ hv_metrics_server_grafana_container_image }}
      env:
        - name: GF_SECURITY_ADMIN_USER
          value: {{ hv_metrics_server_grafana_username }}
        - name: GF_SECURITY_ADMIN_PASSWORD
          value: {{ hv_metrics_server_grafana_password }}
        - name: GF_ANALYTICS_CHECK_FOR_UPDATES
          value: false
        - name: GF_USERS_ALLOW_SIGN_UP
          value: false
      ports:
        - containerPort: 3000
      volumeMounts:
        - name: grafana-provider
          mountPath: /etc/grafana/provisioning/dashboards/provider.yaml
        - name: grafana-dashboard
          mountPath: /etc/grafana/provisioning/dashboards/
        - name: grafana-datasource
          mountPath: /etc/grafana/provisioning/datasources/datasource-prometheus.yaml
{% endif %}
{% if hv_metrics_server_enable_bastion_exporter %}
    - name: {{ hv_metrics_server_bastion_exporter_container_name }}
      image: {{ hv_metrics_server_bastion_exporter_container_image }}
      args:
        - "--path.rootfs=/host"
        - "--path.procfs=/host/proc"
        - "--path.sysfs=/host/sys"
        - "--collector.textfile.directory=/textfile-collector"
      ports:
        - containerPort: 9100
      volumeMounts:
        - name: host-rootfs
          mountPath: /host
          readOnly: true
        - name: textfile-collector
          mountPath: /textfile-collector
          readOnly: true
{% endif %}
  volumes:
    - name: prometheus-data
      hostPath:
        path: {{ hv_metrics_server_podman_data_dir }}
        type: Directory
    - name: prometheus-config
      hostPath:
        path: {{ hv_metrics_server_podman_config_source }}
        type: File
{% if hv_metrics_server_deploy_grafana %}
    - name: grafana-provider
      hostPath:
        path: {{ hv_metrics_server_work_dir }}/dashboard-providers.yaml
        type: File
    - name: grafana-dashboard
      hostPath:
        path: {{ hv_metrics_server_grafana_dashboard_dir }}
        type: Directory
    - name: grafana-datasource
      hostPath:
        path: {{ hv_metrics_server_work_dir }}/datasource-prometheus.yaml
        type: File
{% endif %}
{% if hv_metrics_server_enable_bastion_exporter %}
    - name: host-rootfs
      hostPath:
        path: /
        type: Directory
    - name: textfile-collector
      hostPath:
        path: {{ hv_metrics_server_bastion_exporter_textfile_dir }}
        type: Directory
{% endif %}
